PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/?appName=Cluster0
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
# Optional: comma-separated DNS servers used if SRV DNS lookup is refused by local resolver
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# Resend API key used for match update email notifications.
RESEND_API_KEY=re_********************************
# Verified sender identity in Resend (domain or onboarding sender).
EMAIL_FROM=Baller League <updates@example.com>
